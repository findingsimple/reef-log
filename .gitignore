/.scratch
.DS_Store

# Local Claude Code settings (per-machine permissions)
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/

# Tests / lint
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.ruff_cache/

# Local DB (the real one lives at ~/.reef-log/reef.db, but guard against
# accidental commits if anyone uses --db inside the repo)
*.db
*.db-wal
*.db-shm

# HEIC originals from the iPhone are kept locally for reference but not
# tracked — the JPG fixtures in tests/fixtures/photos/ are what tests use.
tests/fixtures/photos/*.HEIC
tests/fixtures/photos/.DS_Store
tests/fixtures/photos/**/.DS_Store
